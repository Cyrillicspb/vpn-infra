# =============================================================================
# VPN Infrastructure — переменные окружения
# Скопируйте в .env и заполните своими значениями
# НИКОГДА не коммитьте .env в git!
# =============================================================================

# -----------------------------------------------------------------------------
# Домашний сервер — сеть (автоопределение setup.sh)
# -----------------------------------------------------------------------------
HOME_SERVER_IP=
GATEWAY_IP=
NET_INTERFACE=
HOME_SUBNET=

# -----------------------------------------------------------------------------
# Telegram
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# -----------------------------------------------------------------------------
# WireGuard / AmneziaWG
# -----------------------------------------------------------------------------
WG_HOST=            # внешний IP или DDNS-домен
WG_AWG_PORT=51820
WG_WG_PORT=51821
WG_MTU=1320

# -----------------------------------------------------------------------------
# VPS (основной)
# -----------------------------------------------------------------------------
VPS_IP=
VPS_SSH_PORT=443    # или 22
VPS_TUNNEL_IP=10.177.2.2

# -----------------------------------------------------------------------------
# Hysteria2 (стек 4: QUIC + Salamander obfuscation)
# -----------------------------------------------------------------------------
HYSTERIA2_SERVER=
HYSTERIA2_AUTH=            # генерируется setup.sh (openssl rand -hex 32)
HYSTERIA2_OBFS_PASSWORD=   # генерируется setup.sh (openssl rand -hex 16)

# -----------------------------------------------------------------------------
# Xray VLESS+XHTTP+REALITY (стек 3: microsoft.com, порт 2087)
# Протокол: splithttp (XHTTP) — Xray 26.x, flow пустой (vision несовместим)
# -----------------------------------------------------------------------------
XRAY_SERVER=
XRAY_UUID=                 # генерируется setup.sh (uuidgen)
XRAY_PUBLIC_KEY=           # генерируется setup.sh (xray x25519)
XRAY_SOCKS_PORT=1080
XHTTP_MS_PASSWORD=         # генерируется setup.sh — обязателен для Xray 26.x

# -----------------------------------------------------------------------------
# Xray VLESS+XHTTP+REALITY (стек 2: cdn.jsdelivr.net, порт 2083)
# Более устойчив к блокировкам чем microsoft.com
# -----------------------------------------------------------------------------
XRAY_GRPC_UUID=            # генерируется setup.sh (uuidgen)
XRAY_GRPC_PUBLIC_KEY=      # генерируется setup.sh (xray x25519)
XRAY_GRPC_SOCKS_PORT=1081
XHTTP_CDN_PASSWORD=        # генерируется setup.sh — обязателен для Xray 26.x

# -----------------------------------------------------------------------------
# Cloudflare CDN (стек 1 — самый устойчивый, VLESS+xHTTP через Cloudflare)
# Транспорт: splithttp (xHTTP H2) — WebSocket устарел в Xray 26.x
# Инструкция по настройке: setup.sh спросит при установке
# -----------------------------------------------------------------------------

CF_CDN_HOSTNAME=           # hostname для xHTTP CDN, например: xxx.workers.dev или sub.domain.com
CF_CDN_UUID=               # генерируется setup.sh (uuidgen)

# -----------------------------------------------------------------------------
# 3x-ui панель (на VPS)
# -----------------------------------------------------------------------------
XRAY_PANEL_PASSWORD=       # генерируется setup.sh (openssl rand -hex 16)

# -----------------------------------------------------------------------------
# Watchdog
# -----------------------------------------------------------------------------
WATCHDOG_API_TOKEN=

# -----------------------------------------------------------------------------
# Grafana (на VPS) и мониторинг
# -----------------------------------------------------------------------------
GRAFANA_PASSWORD=        # генерируется setup.sh (openssl rand -hex 16)
GRAFANA_LAN_ACCESS=false # true — Grafana доступна по LAN IP:3000 (только на VPS)
DOCKER_SUBNET=172.20.0.0/24  # подсеть Docker на домашнем сервере (при конфликте менять)
GRAFANA_URL=http://localhost:3000
GRAFANA_TOKEN=           # опционально, API-токен Grafana для /graph

# -----------------------------------------------------------------------------
# DDNS (опционально)
# -----------------------------------------------------------------------------
DDNS_PROVIDER=          # duckdns | noip | cloudflare
DDNS_DOMAIN=
DDNS_TOKEN=

# -----------------------------------------------------------------------------
# Домен (опционально, для Cloudflare DDNS)
# -----------------------------------------------------------------------------
DOMAIN=
CF_API_TOKEN=

# -----------------------------------------------------------------------------
# Бэкапы
# -----------------------------------------------------------------------------
BACKUP_GPG_PASSPHRASE=
BACKUP_VPS_HOST=
BACKUP_VPS_USER=sysadmin

# -----------------------------------------------------------------------------
# Опциональные компоненты
# -----------------------------------------------------------------------------
INSTALL_PORTAINER=false
INSTALL_HOMEPAGE=false
INSTALL_WG_EASY=false
INSTALL_CLAUDE_CODE=false
BANDWIDTH_LIMIT=
DEVICE_LIMIT_PER_CLIENT=5
