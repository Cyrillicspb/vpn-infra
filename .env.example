# =============================================================================
# VPN Infrastructure — переменные окружения
# Скопируйте в .env и заполните своими значениями
# НИКОГДА не коммитьте .env в git!
# =============================================================================

# -----------------------------------------------------------------------------
# Домашний сервер — сеть (автоопределение setup.sh)
# -----------------------------------------------------------------------------
HOME_SERVER_IP=
GATEWAY_IP=
NET_INTERFACE=
HOME_SUBNET=

# -----------------------------------------------------------------------------
# Telegram
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# -----------------------------------------------------------------------------
# WireGuard / AmneziaWG
# -----------------------------------------------------------------------------
WG_HOST=            # внешний IP или DDNS-домен
WG_AWG_PORT=51820
WG_WG_PORT=51821
WG_MTU=1320

# -----------------------------------------------------------------------------
# VPS (основной)
# -----------------------------------------------------------------------------
VPS_IP=
VPS_SSH_PORT=443    # или 22
VPS_TUNNEL_IP=10.177.2.2

# -----------------------------------------------------------------------------
# Hysteria2
# -----------------------------------------------------------------------------
HYSTERIA2_SERVER=
HYSTERIA2_AUTH=
HYSTERIA2_OBFS_PASSWORD=

# -----------------------------------------------------------------------------
# Xray VLESS+REALITY
# -----------------------------------------------------------------------------
XRAY_SERVER=
XRAY_UUID=
XRAY_PUBLIC_KEY=
XRAY_SOCKS_PORT=1080
XHTTP_MS_PASSWORD=    # генерируется setup.sh

# -----------------------------------------------------------------------------
# Xray VLESS+REALITY+gRPC
# -----------------------------------------------------------------------------
XRAY_GRPC_UUID=
XRAY_GRPC_PUBLIC_KEY=
XRAY_GRPC_SOCKS_PORT=1081
XHTTP_CDN_PASSWORD=   # генерируется setup.sh

# -----------------------------------------------------------------------------
# Cloudflare CDN (стек 1)
# -----------------------------------------------------------------------------
CF_TUNNEL_TOKEN=

# -----------------------------------------------------------------------------
# Watchdog
# -----------------------------------------------------------------------------
WATCHDOG_API_TOKEN=

# -----------------------------------------------------------------------------
# Grafana (домашний сервер)
# -----------------------------------------------------------------------------
GRAFANA_PASSWORD=        # генерируется setup.sh
GRAFANA_LAN_ACCESS=false # true — доступна по LAN IP:3000
GRAFANA_URL=http://localhost:3000
GRAFANA_TOKEN=           # опционально, API-токен Grafana для /graph

# -----------------------------------------------------------------------------
# DDNS (опционально)
# -----------------------------------------------------------------------------
DDNS_PROVIDER=          # duckdns | noip | cloudflare
DDNS_DOMAIN=
DDNS_TOKEN=

# -----------------------------------------------------------------------------
# Домен (опционально, для Cloudflare DDNS)
# -----------------------------------------------------------------------------
DOMAIN=
CF_API_TOKEN=

# -----------------------------------------------------------------------------
# Бэкапы
# -----------------------------------------------------------------------------
BACKUP_GPG_PASSPHRASE=
BACKUP_VPS_HOST=
BACKUP_VPS_USER=sysadmin

# -----------------------------------------------------------------------------
# Опциональные компоненты
# -----------------------------------------------------------------------------
INSTALL_PORTAINER=false
INSTALL_HOMEPAGE=false
INSTALL_WG_EASY=false
INSTALL_CLAUDE_CODE=false
BANDWIDTH_LIMIT=
DEVICE_LIMIT_PER_CLIENT=5
