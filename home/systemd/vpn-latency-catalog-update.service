[Unit]
Description=Refresh runtime latency catalog
Documentation=https://github.com/Cyrillicspb/vpn-infra/blob/main/docs/TODO-SPECS.md
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=root
EnvironmentFile=-/opt/vpn/.env
ExecStart=/usr/bin/python3 /opt/vpn/scripts/update-latency-catalog.py
StandardOutput=journal
StandardError=journal
SyslogIdentifier=vpn-latency-catalog-update
