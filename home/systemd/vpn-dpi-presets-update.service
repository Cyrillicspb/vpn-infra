[Unit]
Description=Refresh DPI bypass presets from curated public sources
Documentation=https://github.com/Cyrillicspb/vpn-infra/blob/main/docs/TODO-SPECS.md
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=root
EnvironmentFile=-/opt/vpn/.env
ExecStart=/usr/bin/python3 /opt/vpn/scripts/update-dpi-presets.py --reload-watchdog
StandardOutput=journal
StandardError=journal
SyslogIdentifier=vpn-dpi-presets-update
