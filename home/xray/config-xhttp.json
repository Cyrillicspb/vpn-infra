{
  "log": {
    "loglevel": "warning"
  },
  "inbounds": [
    {
      "listen": "127.0.0.1",
      "port": 1081,
      "protocol": "socks",
      "settings": {
        "auth": "noauth",
        "udp": true
      },
      "tag": "socks-xhttp-in"
    }
  ],
  "outbounds": [
    {
      "protocol": "vless",
      "settings": {
        "vnext": [
          {
            "address": "${XRAY_SERVER}",
            "port": 2083,
            "users": [
              {
                "id": "${XRAY_XHTTP_UUID}",
                "encryption": "none",
                "flow": ""
              }
            ]
          }
        ]
      },
      "streamSettings": {
        "network": "xhttp",
        "security": "reality",
        "realitySettings": {
          "serverName": "cdn.jsdelivr.net",
          "fingerprint": "chrome",
          "publicKey": "${XRAY_XHTTP_PUBLIC_KEY}",
          "shortId": "${XRAY_XHTTP_SHORT_ID}"
        },
        "xhttpSettings": {
          "path": "/",
          "password": "${XHTTP_CDN_PASSWORD}",
          "mode": "packet-up"
        }
      },
      "tag": "vless-reality-xhttp-out"
    },
    {
      "protocol": "freedom",
      "tag": "direct"
    },
    {
      "protocol": "blackhole",
      "tag": "block"
    }
  ],
  "routing": {
    "domainStrategy": "IPIfNonMatch",
    "rules": [
      {
        "type": "field",
        "ip": ["geoip:private"],
        "outboundTag": "direct"
      }
    ]
  }
}
