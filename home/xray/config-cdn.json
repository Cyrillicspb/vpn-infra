{
    "log": {"loglevel": "warning"},
    "inbounds": [{
        "listen": "127.0.0.1",
        "port": 1082,
        "protocol": "socks",
        "settings": {"udp": true}
    }],
    "outbounds": [{
        "protocol": "vless",
        "settings": {
            "vnext": [{
                "address": "${CF_CDN_HOSTNAME}",
                "port": 443,
                "users": [{"id": "${CF_CDN_UUID}", "encryption": "none", "flow": ""}]
            }]
        },
        "streamSettings": {
            "network": "splithttp",
            "security": "tls",
            "tlsSettings": {
                "serverName": "${CF_CDN_HOSTNAME}",
                "alpn": ["h2", "http/1.1"],
                "allowInsecure": false
            },
            "splithttpSettings": {
                "path": "/vpn-cdn",
                "host": "${CF_CDN_HOSTNAME}",
                "xPaddingBytes": "100-1000"
            },
            "sockopt": {"mark": 254}
        },
        "tag": "vless-xhttp-cdn-out"
    },
    {
        "protocol": "freedom",
        "tag": "direct"
    }],
    "routing": {
        "domainStrategy": "IPIfNonMatch",
        "rules": [{
            "type": "field",
            "ip": ["geoip:private"],
            "outboundTag": "direct"
        }]
    }
}
