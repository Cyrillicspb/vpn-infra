{
    "log": {"loglevel": "warning"},
    "inbounds": [{
        "listen": "127.0.0.1",
        "port": 1082,
        "protocol": "socks",
        "settings": {"udp": true}
    }],
    "outbounds": [{
        "protocol": "vless",
        "settings": {
            "vnext": [{
                "address": "YOUR_WORKER.workers.dev",
                "port": 443,
                "users": [{"id": "YOUR_CF_CDN_UUID", "encryption": "none", "flow": ""}]
            }]
        },
        "streamSettings": {
            "network": "ws",
            "security": "tls",
            "tlsSettings": {"serverName": "YOUR_WORKER.workers.dev", "allowInsecure": false},
            "wsSettings": {
                "path": "/vpn-cdn",
                "headers": {"Host": "YOUR_WORKER.workers.dev"}
            }
        }
    }]
}
