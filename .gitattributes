# Line endings
* text=auto

# Windows scripts — always CRLF
*.bat  text eol=crlf
*.cmd  text eol=crlf
*.ps1  text eol=crlf

# Unix scripts — always LF
*.sh   text eol=lf
*.py   text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.json text eol=lf
*.conf text eol=lf
*.md   text eol=lf

# macOS installer — LF (runs in bash)
*.command text eol=lf

# Binaries — no conversion
*.png  binary
*.jpg  binary
*.gif  binary
*.ico  binary
*.gz   binary
*.zip  binary
